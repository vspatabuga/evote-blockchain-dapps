{
  "name": "@vspatabuga/sim-ledger",
  "version": "1.0.0",
  "description": "VSP Blockchain Ledger Simulation - Immutable Voting System",
  "type": "module",
  "main": "simulate.sh",
  "bin": {
    "vsp-sim-ledger": "./simulate.sh"
  },
  "scripts": {
    "simulate": "bash simulate.sh",
    "start": "docker compose -p vsp-ledger up -d",
    "stop": "docker compose -p vsp-ledger down",
    "clean": "docker compose -p vsp-ledger down -v",
    "logs": "docker compose -p vsp-ledger logs -f"
  },
  "keywords": [
    "vsp",
    "sim-ledger",
    "blockchain",
    "voting",
    "ethereum",
    "simulation",
    "sovereign-systems"
  ],
  "author": "VSP (Virgiawan Sagarmata Patabuga)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/vspatabuga/evote-blockchain-dapps.git"
  },
  "publishConfig": {
    "registry": "https://npm.pkg.github.com"
  },
  "files": [
    "simulate.sh",
    "docker-compose.yml",
    "Dockerfile.api",
    "Dockerfile.client",
    "client/",
    "contracts/",
    "simulation/",
    "docs/",
    "README.md"
  ]
}
